# Recuperación de acceso dashboard (opcional)
MASTER_RECOVERY_KEY=

# Google Gemini (tienda IA, marketing, B2B)
GEMINI_API_KEY=
GEMINI_API_KEY_PAID=
GEMINI_MODEL=gemini-2.5-flash-lite
