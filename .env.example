# IMPROGYP — copia a .env y ajusta valores (MAMP local)
# cp .env.example .env

# MySQL (MAMP: puerto 8889, usuario root)
DB_HOST=127.0.0.1
DB_PORT=8889
DB_NAME=u718580158_improgyp
DB_USER=root
DB_PASS=root

# Solo se usa si la tabla usuarios_admin está vacía (primer arranque)
